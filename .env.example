# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Maps Platform Key (added for interactive mapping)
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_KEY_HERE"
VITE_GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_KEY_HERE"

# SMTP (Gmail/Custom) Settings for real email notifications
# For Gmail, use host "smtp.gmail.com", port 587, and use an App Password for SMTP_PASS (not your normal password).
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# Twilio Settings for real SMS and WhatsApp notifications
# Twilio credentials can be found in your Twilio Console (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

